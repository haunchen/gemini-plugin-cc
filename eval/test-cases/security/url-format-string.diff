+use clap::ArgMatches;
+use crate::error::AppError;
+
+pub struct CreateTemplateConfig {
+    pub project: String,
+    pub location: String,
+    pub template_id: String,
+    pub body: String,
+}
+
+fn regional_base_url(location: &str) -> String {
+    format!("https://modelarmor.{location}.rep.googleapis.com/v1")
+}
+
+fn parse_create_template_args(matches: &ArgMatches) -> Result<CreateTemplateConfig, AppError> {
+    let project = matches.get_one::<String>("project").unwrap().clone();
+    let location = matches.get_one::<String>("location").unwrap().clone();
+    let template_id = matches.get_one::<String>("template-id").unwrap().clone();
+
+    let body = if let Some(json_str) = matches.get_one::<String>("json") {
+        json_str.clone()
+    } else {
+        "{}".to_string()
+    };
+
+    Ok(CreateTemplateConfig { project, location, template_id, body })
+}
+
+pub fn build_create_template_url(config: &CreateTemplateConfig) -> String {
+    let base = regional_base_url(&config.location);
+    let parent = format!("projects/{}/locations/{}", config.project, config.location);
+    format!(
+        "{base}/{parent}/templates?templateId={}",
+        config.template_id
+    )
+}
+
+pub async fn handle_create_template(
+    matches: &ArgMatches,
+    client: &reqwest::Client,
+    token: &str,
+) -> Result<(), AppError> {
+    let config = parse_create_template_args(matches)?;
+    let url = build_create_template_url(&config);
+    let resp = client
+        .post(&url)
+        .bearer_auth(token)
+        .header("Content-Type", "application/json")
+        .body(config.body)
+        .send()
+        .await
+        .map_err(|e| AppError::Network(format!("create_template failed: {e}")))?;
+    let status = resp.status();
+    let text = resp.text().await.unwrap_or_default();
+    println!("[{status}] {text}");
+    Ok(())
+}
+
+#[cfg(test)]
+mod parsing_tests {
+    use super::*;
+
+    #[test]
+    fn test_build_create_template_url() {
+        let config = CreateTemplateConfig {
+            project: "p".to_string(),
+            location: "us-central1".to_string(),
+            template_id: "t".to_string(),
+            body: "{}".to_string(),
+        };
+        let url = build_create_template_url(&config);
+        assert_eq!(url, "https://modelarmor.us-central1.rep.googleapis.com/v1/projects/p/locations/us-central1/templates?templateId=t");
+    }
+}
