+/**
+ * 清理檔名中可能造成 FFmpeg 指令問題的特殊字元，
+ * 僅保留英數字、中日韓文字、底線、連字號與句點。
+ */
+export function sanitizeFileName(name: string): string {
+  const stripped = name.replace(/.*[\\/]/, "");
+  const dotIndex = stripped.lastIndexOf(".");
+  const baseName = dotIndex > 0 ? stripped.slice(0, dotIndex) : stripped;
+  const ext = dotIndex > 0 ? stripped.slice(dotIndex) : "";
+  const sanitized = baseName.replace(/[^\w\u4e00-\u9fff\u3040-\u309f\u30a0-\u30ff.-]/g, "_");
+  return (sanitized || "file") + ext;
+}
